{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loudline",
  "version": "0.5.0",
  "identifier": "app.loudline",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "VITE_BASE_PATH=/ bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loudline",
        "width": 1280,
        "height": 900,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "backgroundColor": "#0b0d10",
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Offline LUFS loudness metering",
    "longDescription": "Analyze audio loudness locally with EBU R128 / ITU-R BS.1770 metering, waveforms, and preview playback."
  }
}
